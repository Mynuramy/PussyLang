// ── Minesweeper (string‑based, 10x10) ──────────────────────────────

var COLS   = 10;
var ROWS   = 10;
var TOTAL  = 100;
var MINES  = 15;

// ── Grid helpers (identical to Game of Life) ────────────────────────

func get_cell(grid_string, col, row) {
    if (col < 0)    { return 0; }
    if (row < 0)    { return 0; }
    if (col >= COLS){ return 0; }
    if (row >= ROWS){ return 0; }
    var grid_bytes = cast(grid_string, "bytes");
    var index      = row * COLS + col;
    var byte_val   = (grid_bytes[index] + 255 + 1) % (255 + 1);
    if (byte_val == 49) { return 1; }   // '1' = mine
    return 0;
}

func set_cell_on(grid_string, col, row) {
    var index      = row * COLS + col;
    var grid_bytes = cast(grid_string, "bytes");
    var new_grid   = "";
    var i = 0;
    while (i < TOTAL) {
        if (i == index) {
            new_grid = new_grid + "1";
        } else {
            var b = (grid_bytes[i] + 255 + 1) % (255 + 1);
            new_grid = new_grid + chr(b);
        }
        i = i + 1;
    }
    return new_grid;
}

func make_empty_grid() {
    var g = "";
    var i = 0;
    while (i < TOTAL) {
        g = g + "0";
        i = i + 1;
    }
    return g;
}

// ── Random number 0 .. max-1 ───────────────────────────────────────
func random_int(max) {
    var t = cast(clock() * 1000, "int") % max;
    return t;
}

// ── Mine placement ──────────────────────────────────────────────────
func place_mines() {
    var mine_grid = make_empty_grid();
    var placed = 0;
    while (placed < MINES) {
        var col = random_int(COLS);
        var row = random_int(ROWS);
        if (get_cell(mine_grid, col, row) == 0) {
            mine_grid = set_cell_on(mine_grid, col, row);
            placed = placed + 1;
        }
    }
    return mine_grid;
}

// ── Adjacent mine count ─────────────────────────────────────────────
func count_adjacent_mines(mine_grid, col, row) {
    var count = 0;
    count = count + get_cell(mine_grid, col-1, row-1);
    count = count + get_cell(mine_grid, col,   row-1);
    count = count + get_cell(mine_grid, col+1, row-1);
    count = count + get_cell(mine_grid, col-1, row);
    count = count + get_cell(mine_grid, col+1, row);
    count = count + get_cell(mine_grid, col-1, row+1);
    count = count + get_cell(mine_grid, col,   row+1);
    count = count + get_cell(mine_grid, col+1, row+1);
    return count;
}

// ── Reveal a single cell (no flood) ─────────────────────────────────
// This just marks the cell as revealed (sets its char to '1' in revealed_grid).
func reveal_single(revealed_grid, col, row) {
    return set_cell_on(revealed_grid, col, row);
}

// ── Check if cell is already revealed ───────────────────────────────
func is_revealed(revealed_grid, col, row) {
    return get_cell(revealed_grid, col, row);
}

// ── Flood fill using a manual stack (comma‑separated coordinates) ───
// We use a string like "col,row col,row ..." to store positions.
func flood_fill(mine_grid, revealed_grid, start_col, start_row) {
    var stack = str(start_col) + "," + str(start_row);   // initial position
    var result = revealed_grid;
    // safety counter to prevent infinite loops
    var safety = 0;

    while (len(stack) > 0) {
        if (safety > 500) { return result; }
        safety = safety + 1;

        // Extract first coordinate pair from stack
        var space_pos = -1;
        var i = 0;
        var stack_bytes = cast(stack, "bytes");
        while (i < len(stack)) {
            if (chr((stack_bytes[i] + 255 + 1) % (255 + 1)) == " ") {
                space_pos = i;
                i = 9999;
            }
            i = i + 1;
        }

        var coord = "";
        if (space_pos == -1) {
            coord = stack;          // last item
            stack = "";
        } else {
            // everything before the space
            var j = 0;
            while (j < space_pos) {
                coord = coord + chr((stack_bytes[j] + 255 + 1) % (255 + 1));
                j = j + 1;
            }
            // new stack = everything after the space
            var new_stack = "";
            j = space_pos + 1;
            while (j < len(stack_bytes)) {
                new_stack = new_stack + chr((stack_bytes[j] + 255 + 1) % (255 + 1));
                j = j + 1;
            }
            stack = new_stack;
        }

        // Parse coordinate: "col,row"
        var comma_pos = -1;
        var coord_bytes = cast(coord, "bytes");
        var k = 0;
        while (k < len(coord)) {
            if (chr((coord_bytes[k] + 255 + 1) % (255 + 1)) == ",") {
                comma_pos = k;
                k = 9999;
            }
            k = k + 1;
        }
        var col_str = "";
        var m = 0;
        while (m < comma_pos) {
            col_str = col_str + chr((coord_bytes[m] + 255 + 1) % (255 + 1));
            m = m + 1;
        }
        var row_str = "";
        m = comma_pos + 1;
        while (m < len(coord)) {
            row_str = row_str + chr((coord_bytes[m] + 255 + 1) % (255 + 1));
            m = m + 1;
        }
        var col = parse_int(col_str);
        var row = parse_int(row_str);

        // Ignore if already revealed or out of bounds
        if (col >= 0) {
            if (col < COLS) {
                if (row >= 0) {
                    if (row < ROWS) {
                        if (is_revealed(result, col, row) == 0) {
                            result = reveal_single(result, col, row);
                            var adj = count_adjacent_mines(mine_grid, col, row);
                            if (adj == 0) {
                                // push all 8 neighbors onto stack
                                var pushes = "";
                                var r_off = -1;
                                while (r_off <= 1) {
                                    var c_off = -1;
                                    while (c_off <= 1) {
                                        if (c_off != 0) {
                                            var nr = row + r_off;
                                            var nc = col + c_off;
                                            if (nc >= 0) {
                                                if (nr >= 0) {
                                                    if (nc < COLS) {
                                                        if (nr < ROWS) {

                                                            if (c_off != 0 || r_off != 0) {
                                                                pushes = pushes + str(nc) + "," + str(nr) + " ";
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                        c_off = c_off + 1;
                                    }
                                    r_off = r_off + 1;
                                }
                                // append pushes at front (or back) – order doesn't matter
                                stack = pushes + stack;
                            }
                        }
                    }
                }
            }
        }
    }
    return result;
}

// ── Player reveal action ─────────────────────────────────────────────
func player_reveal(mine_grid, revealed_grid, col, row) {
    // if already revealed, do nothing
    if (is_revealed(revealed_grid, col, row) == 1) {
        return revealed_grid;
    }
    // if it's a mine, game over – caller will detect
    if (get_cell(mine_grid, col, row) == 1) {
        return revealed_grid;
    }
    // reveal and maybe flood fill
    var adj = count_adjacent_mines(mine_grid, col, row);
    if (adj == 0) {
        return flood_fill(mine_grid, revealed_grid, col, row);
    } else {
        return reveal_single(revealed_grid, col, row);
    }
}

// ── Check win condition: all safe cells revealed ─────────────────────
func check_win(mine_grid, revealed_grid) {
    var row = 0;
    while (row < ROWS) {
        var col = 0;
        while (col < COLS) {
            if (get_cell(mine_grid, col, row) == 0) {
                if (is_revealed(revealed_grid, col, row) == 0) {
                    return 0;   // still hidden safe cell
                }
            }
            col = col + 1;
        }
        row = row + 1;
    }
    return 1;   // all safe cells revealed
}

// ── Display board ───────────────────────────────────────────────────
func display_board(mine_grid, revealed_grid) {
    var CLEAR = chr(27) + "[2J" + chr(27) + "[H";
    print CLEAR;
    print " MINESWEEPER";
    print "";
    // column numbers
    var header = "   ";
    var c = 0;
    while (c < COLS) {
        if (c < 10) { header = header + " "; }
        header = header + str(c) + " ";
        c = c + 1;
    }
    print header;


    var row = 0;
    while (row < ROWS) {
        var line = "";
        if (row < 10) { line = " "; }
        line = line + str(row) + " │";
        var col = 0;
        while (col < COLS) {
            if (is_revealed(revealed_grid, col, row) == 1) {
                if (get_cell(mine_grid, col, row) == 1) {
                    line = line + " 💣";     // mine revealed (lose condition)
                } else {
                    var adj = count_adjacent_mines(mine_grid, col, row);
                    if (adj == 0) {
                        line = line + " · ";
                    } else {
                        line = line + " " + str(adj) + " ";
                    }
                }
            } else {
                line = line + " ██";       // hidden cell
            }
            col = col + 1;
        }
        print line + "│";
        row = row + 1;
    }
    print "";
}

// ── Parsing helpers ──────────────────────────────────────────────────
func parse_int(s) {
    var sb  = cast(s, "bytes");
    var val = 0;
    var i   = 0;
    while (i < len(sb)) {
        var d = (sb[i] + 255 + 1) % (255 + 1);
        if (d >= 48) { if (d <= 57) { val = val * 10 + (d - 48); } }
        i = i + 1;
    }
    return val;
}

func parse_coords(input_str) {
    var bytes = cast(input_str, "bytes");
    var div_pos = -1;
    var i = 0;
    while (i < len(input_str)) {
        var ch = chr((bytes[i] + 255 + 1) % (255 + 1));
        if (ch == " ") { div_pos = i; i = 9999; }
        if (ch == ",") { div_pos = i; i = 9999; }
        i = i + 1;
    }
    var col_str = "";
    var row_str = "";
    if (div_pos == -1) {
        col_str = input_str;
        row_str = "0";
    } else {
        var j = 0;
        while (j < div_pos) {
            col_str = col_str + chr((bytes[j] + 255 + 1) % (255 + 1));
            j = j + 1;
        }
        j = div_pos + 1;
        while (j < len(input_str)) {
            row_str = row_str + chr((bytes[j] + 255 + 1) % (255 + 1));
            j = j + 1;
        }
    }
    var col = parse_int(col_str);
    var row = parse_int(row_str);
    return str(col) + "," + str(row);
}

// ── Main game loop ───────────────────────────────────────────────────
var mine_grid = place_mines();
var revealed_grid = make_empty_grid();
var game_over = 0;
var win = 0;

while (game_over == 0) {
    display_board(mine_grid, revealed_grid);
    var cmd = input("Enter column row (e.g. '3 4' or '3,4') or q to quit: ");
    if (cmd == "q") {
        game_over = 1;
    }
    if (game_over == 0) {
        var coords = parse_coords(cmd);
        // split coords again (it's "col,row")
        var comma_pos = -1;
        var cbytes = cast(coords, "bytes");
        var i = 0;
        while (i < len(coords)) {
            if (chr((cbytes[i] + 255 + 1) % (255 + 1)) == ",") {
                comma_pos = i;
                i = 9999;
            }
            i = i + 1;
        }
        var col_str = "";
        var j = 0;
        while (j < comma_pos) {
            col_str = col_str + chr((cbytes[j] + 255 + 1) % (255 + 1));
            j = j + 1;
        }
        var row_str = "";
        j = comma_pos + 1;
        while (j < len(coords)) {
            row_str = row_str + chr((cbytes[j] + 255 + 1) % (255 + 1));
            j = j + 1;
        }
        var col = parse_int(col_str);
        var row = parse_int(row_str);

        if (col < 0) { col = 0; }
        if (row < 0) { row = 0; }
        if (col >= COLS) { col = COLS - 1; }
        if (row >= ROWS) { row = ROWS - 1; }

        // Check if hit a mine
        if (get_cell(mine_grid, col, row) == 1) {
            game_over = 1;
            win = 0;
            // reveal all mines for final display
            var r2 = 0;
            while (r2 < ROWS) {
                var c2 = 0;
                while (c2 < COLS) {
                    if (get_cell(mine_grid, c2, r2) == 1) {
                        revealed_grid = reveal_single(revealed_grid, c2, r2);
                    }
                    c2 = c2 + 1;
                }
                r2 = r2 + 1;
            }
        } else {
            revealed_grid = player_reveal(mine_grid, revealed_grid, col, row);
            if (check_win(mine_grid, revealed_grid) == 1) {
                game_over = 1;
                win = 1;
            }
        }
    }
}

display_board(mine_grid, revealed_grid);
if (win == 1) {
    print "YOU WIN! All safe cells revealed.";
} else {
    print "BOOM! You hit a mine. Game Over.";
}
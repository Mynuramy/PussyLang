

var get_async_key = get_proc("user32.dll", "GetAsyncKeyState");

if (get_async_key == 0) {
    print "ERROR: GetAsyncKeyState not found";
    return;
}

var VK_F1 = 112;
var f1_was_down = 0;
var clicker_running = 0;

func key_down() {
    var raw = call(get_async_key, "int", "i", VK_F1);
    if (raw == null) { return 0; }
    var val = raw;
    if (val < 0) { return 1; }
    if (val >= 32768) { return 1; }
    return 0;
}

func launch_clicker() {
    system("start /B clicker.exe");
    print "Launched clicker.exe";
}

func kill_clicker() {
    system("taskkill /F /IM clicker.exe > nul 2>&1");
    print "Killed clicker.exe";
}

print "Manager running. Press F1 to start/stop clicker.exe.";
print "Make sure clicker.exe is in the same directory you can change that tho.";

while (1 == 1) {
    var now = key_down();
    if (now == 1) {
        if (f1_was_down == 0) {
            if (clicker_running == 0) {
                launch_clicker();
                clicker_running = 1;
            } else {
                kill_clicker();
                clicker_running = 0;
            }
            sleep(200);
        }
    }
    f1_was_down = now;
    sleep(30);
}

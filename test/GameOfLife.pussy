var COLS  = 16;
var ROWS  = 12;
var TOTAL = 192;


func get_cell(grid_string, col, row) {
    if (col < 0)    { return 0; }
    if (row < 0)    { return 0; }
    if (col >= COLS){ return 0; }
    if (row >= ROWS){ return 0; }
    var grid_bytes = cast(grid_string, "bytes");
    var index      = row * COLS + col;
    var byte_val   = (grid_bytes[index] + 256) % 256;
    if (byte_val == 49) { return 1; }
    return 0;
}

func set_cell_on(grid_string, col, row) {
    var index      = row * COLS + col;
    var grid_bytes = cast(grid_string, "bytes");
    var new_grid   = "";
    var i = 0;
    while (i < TOTAL) {
        if (i == index) {
            new_grid = new_grid + "1";
        } else {
            var b = (grid_bytes[i] + 256) % 256;
            new_grid = new_grid + chr(b);
        }
        i = i + 1;
    }
    return new_grid;
}


func count_neighbors(grid_string, col, row) {
    var n = 0;
    n = n + get_cell(grid_string, col - 1, row - 1);
    n = n + get_cell(grid_string, col,     row - 1);
    n = n + get_cell(grid_string, col + 1, row - 1);
    n = n + get_cell(grid_string, col - 1, row    );
    n = n + get_cell(grid_string, col + 1, row    );
    n = n + get_cell(grid_string, col - 1, row + 1);
    n = n + get_cell(grid_string, col,     row + 1);
    n = n + get_cell(grid_string, col + 1, row + 1);
    return n;
}


func next_generation(grid_string) {
    var new_grid = "";
    var row = 0;
    while (row < ROWS) {
        var col = 0;
        while (col < COLS) {
            var alive     = get_cell(grid_string, col, row);
            var neighbors = count_neighbors(grid_string, col, row);
            var next_state = 0;
            if (alive == 1) {
                if (neighbors == 2) { next_state = 1; }
                if (neighbors == 3) { next_state = 1; }
            } else {
                if (neighbors == 3) { next_state = 1; }
            }
            if (next_state == 1) {
                new_grid = new_grid + "1";
            } else {
                new_grid = new_grid + "0";
            }
            col = col + 1;
        }
        row = row + 1;
    }
    return new_grid;
}


func count_alive(grid_string) {
    var grid_bytes = cast(grid_string, "bytes");
    var count = 0;
    var i = 0;
    while (i < TOTAL) {
        var b = (grid_bytes[i] + 256) % 256;
        if (b == 49) { count = count + 1; }
        i = i + 1;
    }
    return count;
}

func display_grid(grid_string, generation) {
    var alive_count = count_alive(grid_string);
    print "Gen " + str(generation) + "  alive: " + str(alive_count);
    print "-----------------------------------";
    var row = 0;
    while (row < ROWS) {
        var line = "│";
        var col = 0;
        while (col < COLS) {
            var cell = get_cell(grid_string, col, row);
            if (cell == 1) {
                line = line + "██";
            } else {
                line = line + "  ";
            }
            col = col + 1;
        }
        print line + "│";
        row = row + 1;
    }
    print "-----------------------------------";
    print "";
}


func make_empty_grid() {
    var g = "";
    var i = 0;
    while (i < TOTAL) {
        g = g + "0";
        i = i + 1;
    }
    return g;
}

func place_glider(grid_string, col, row) {
    var g = grid_string;
    g = set_cell_on(g, col + 1, row    );
    g = set_cell_on(g, col + 2, row + 1);
    g = set_cell_on(g, col,     row + 2);
    g = set_cell_on(g, col + 1, row + 2);
    g = set_cell_on(g, col + 2, row + 2);
    return g;
}

func place_blinker(grid_string, col, row) {
    var g = grid_string;
    g = set_cell_on(g, col,     row);
    g = set_cell_on(g, col + 1, row);
    g = set_cell_on(g, col + 2, row);
    return g;
}

func place_r_pentomino(grid_string, col, row) {
    var g = grid_string;
    g = set_cell_on(g, col + 1, row    );
    g = set_cell_on(g, col + 2, row    );
    g = set_cell_on(g, col,     row + 1);
    g = set_cell_on(g, col + 1, row + 1);
    g = set_cell_on(g, col + 1, row + 2);
    return g;
}

func place_beacon(grid_string, col, row) {
    var g = grid_string;
    g = set_cell_on(g, col,     row    );
    g = set_cell_on(g, col + 1, row    );
    g = set_cell_on(g, col,     row + 1);
    g = set_cell_on(g, col + 3, row + 2);
    g = set_cell_on(g, col + 2, row + 3);
    g = set_cell_on(g, col + 3, row + 3);
    return g;
}

func place_two_gliders(grid_string) {
    var g = grid_string;
    g = place_glider(g, 1, 1);
    g = place_glider(g, 9, 6);
    return g;
}


func parse_int(s) {
    var sb  = cast(s, "bytes");
    var val = 0;
    var i   = 0;
    while (i < len(sb)) {
        var d = (sb[i] + 256) % 256;
        if (d >= 48) {
            if (d <= 57) {
                val = val * 10 + (d - 48);
            }
        }
        i = i + 1;
    }
    return val;
}

print " Game of life <3";

print "  1  Glider          — diagonal traveller";
print "  2  Blinker         — period-2 oscillator";
print "  3  R-pentomino     — chaotic long-liver";
print "  4  Beacon          — period-2 oscillator";
print "  5  Two gliders     — collision course";
print "";

var pattern_input = input("Pattern (1-5, default 1): ");
var gen_input     = input("Generations (default 20):  ");

var pattern_id = parse_int(pattern_input);
var gen_count  = parse_int(gen_input);

if (pattern_id < 1) { pattern_id = 1; }
if (pattern_id > 5) { pattern_id = 1; }
if (gen_count  < 1) { gen_count  = 20; }
if (gen_count  > 500){ gen_count  = 500; }

var grid = make_empty_grid();

if (pattern_id == 1) {
    print "Pattern: Glider";
    grid = place_glider(grid, 1, 1);
}
if (pattern_id == 2) {
    print "Pattern: Blinker";
    grid = place_blinker(grid, 6, 5);
}
if (pattern_id == 3) {
    print "Pattern: R-pentomino";
    grid = place_r_pentomino(grid, 7, 4);
}
if (pattern_id == 4) {
    print "Pattern: Beacon";
    grid = place_beacon(grid, 5, 4);
}
if (pattern_id == 5) {
    print "Pattern: Two gliders";
    grid = place_two_gliders(grid);
}

var CLEAR = chr(27) + "[2J" + chr(27) + "[H";


var speed_input = input("Frame delay ms (default 150): ");
var frame_delay = parse_int(speed_input);
if (frame_delay < 50)  { frame_delay = 50;  }
if (frame_delay > 2000){ frame_delay = 2000; }


print CLEAR;
display_grid(grid, 0);

var gen_idx = 1;
while (gen_idx <= gen_count) {
    sleep(frame_delay);
    grid = next_generation(grid);
    print CLEAR;
    display_grid(grid, gen_idx);
    gen_idx = gen_idx + 1;
}

print "Simulation complete: " + str(gen_count) + " generations.";
